# PowerDetect Sherlock environment template
# Copy this file to .env.local for local development.
# Keep real secrets out of Git.

SHERLOCK_APP_NAME=Sherlock
SHERLOCK_BRAND=PowerDetect
SHERLOCK_MARKETING_NAME="PowerDetect Sherlock"
SHERLOCK_CATEGORY="AI Launch Security Audit + Scanner"
SHERLOCK_CURRENT_PHASE="Phase 9 Backend API Foundation completed"
SHERLOCK_ENVIRONMENT=local
SHERLOCK_API_VERSION=v0
SHERLOCK_DEBUG=false
SHERLOCK_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4173

# Future app/API URLs
SHERLOCK_APP_URL=http://localhost:3000
SHERLOCK_API_BASE_URL=http://localhost:8000

# Future database/auth providers
DATABASE_URL=replace-with-database-url
SUPABASE_URL=replace-with-supabase-url
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-supabase-service-role-key

# Future queue/cache
REDIS_URL=replace-with-redis-url

# Future billing
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret

# Future AI provider integrations
AI_PROVIDER=openai
OPENAI_API_KEY=replace-with-openai-api-key
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# Future observability
SENTRY_DSN=replace-with-sentry-dsn
